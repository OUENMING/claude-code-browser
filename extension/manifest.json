{
  "manifest_version": 3,
  "name": "Claude Code 浏览器助手",
  "version": "1.0.0",
  "permissions": ["debugger", "tabs", "tabGroups", "activeTab", "scripting", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" } },
  "content_scripts": [
    { "matches": ["http://*/*", "https://*/*"], "js": ["content-scripts/accessibility-tree.js"], "run_at": "document_idle" },
    { "matches": ["http://*/*", "https://*/*"], "js": ["content-scripts/page-bridge.js"], "run_at": "document_idle" },
    { "matches": ["http://*/*", "https://*/*"], "js": ["content-scripts/auto-capture.js"], "run_at": "document_idle" },
    { "matches": ["http://*/*", "https://*/*"], "js": ["content-scripts/visual-indicator.js"], "run_at": "document_idle" }
  ],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
